# ── AgentWall Configuration ──────────────────────────────────────────
# Copy this file to .env and fill in your values

# GitHub App credentials (get these from https://github.com/settings/apps)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=./private-key.pem
GITHUB_WEBHOOK_SECRET=

# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_PATH=./data/agentwall.db

# Dashboard auth (set a strong password for your dashboard)
DASHBOARD_SECRET=change-me-to-a-strong-secret

# Enforcement behavior
# MONITOR_ONLY=true records what each policy WOULD do without touching PRs
MONITOR_ONLY=false
# Comma-separated GitHub logins that bypass scanning entirely
ALLOWLIST=
# Set to false to also scan registered GitHub App bots (dependabot etc.)
SKIP_BOTS=true
# Post a check run with the scan result on every analyzed PR
# (requires the app's "Checks: Read & write" permission)
CHECKS_ENABLED=true

# Logging
LOG_LEVEL=info
